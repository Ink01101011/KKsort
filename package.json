{
  "name": "@kktestdev/kksort",
  "version": "1.0.1",
  "description": "TypeScript sorting algorithms library with tree-shakable imports and full type safety",
  "keywords": [
    "sort",
    "sorting",
    "algorithm",
    "algorithms",
    "typescript",
    "quicksort",
    "mergesort",
    "bubblesort",
    "heapsort",
    "insertionsort",
    "selectionsort",
    "tree-shaking",
    "esm",
    "typescript-library",
    "data-structures"
  ],
  "homepage": "https://github.com/Ink01101011/KKsort#readme",
  "bugs": {
    "url": "https://github.com/Ink01101011/KKsort/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ink01101011/KKsort.git"
  },
  "license": "ISC",
  "author": "Ink01101011",
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bubble": {
      "types": "./dist/algorithms/sort/bubble.d.ts",
      "default": "./dist/algorithms/sort/bubble.js"
    },
    "./heap": {
      "types": "./dist/algorithms/sort/heap.d.ts",
      "default": "./dist/algorithms/sort/heap.js"
    },
    "./insertion": {
      "types": "./dist/algorithms/sort/insertion.d.ts",
      "default": "./dist/algorithms/sort/insertion.js"
    },
    "./merge": {
      "types": "./dist/algorithms/sort/merge.d.ts",
      "default": "./dist/algorithms/sort/merge.js"
    },
    "./quick": {
      "types": "./dist/algorithms/sort/quick.d.ts",
      "default": "./dist/algorithms/sort/quick.js"
    },
    "./selection": {
      "types": "./dist/algorithms/sort/selection.d.ts",
      "default": "./dist/algorithms/sort/selection.js"
    },
    "./sort": {
      "types": "./dist/algorithms/sort/index.d.ts",
      "default": "./dist/algorithms/sort/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepublishOnly": "npm run build",
    "pre-publish": "node scripts/pre-publish.js",
    "validate": "npm run lint && npm run format:check && npm test && npm run build",
    "check-size": "npm pack --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1"
  }
}
